    <file>src/app/admin/layout.tsx</file>
    <content><![CDATA[
'use client';

import { useEffect, useState, useRef, useCallback } from 'react';
import { useRouter } from 'next/navigation';
import { Loader2, BellOff } from 'lucide-react';
import { onSnapshot, collection, getFirestore, query } from 'firebase/firestore';
import { getAuth, onAuthStateChanged, setPersistence, browserLocalPersistence, type User } from 'firebase/auth';

import AdminSidebar from '@/components/admin-sidebar';
import { useAuthStore } from '@/store/auth';
import { useToast } from '@/hooks/use-toast';
import { getFirebaseApp } from '@/lib/firebase';
import { ADMIN_USER_UIDS } from '@/lib/admins';
import { AlarmProvider, useAlarm } from '@/context/alarm-context';
import { Button } from '@/components/ui/button';

// O conteúdo principal do layout, que agora consome o contexto de alarme
function AdminContent({ children }: { children: React.ReactNode }) {
    const { isRinging, stopRinging } = useAlarm();

    return (
        <>
            {isRinging && (
                <div className="fixed top-4 right-4 z-50 no-print">
                    <Button onClick={stopRinging} variant="destructive" size="lg" className="flex items-center gap-2 animate-pulse">
                        <BellOff className="h-5 w-5"/>
                        Silenciar Alarme
                    </Button>
                </div>
            )}
            <main className="flex-1 p-8 bg-muted/30">
                {children}
            </main>
        </>
    );
}


// O Layout principal que agora age como o controlador do alarme
function AdminLayoutController({ children }: { children: React.ReactNode }) {
  const { user, setUser, isAuthLoading, logout } = useAuthStore();
  const router = useRouter();
  const { toast } = useToast();
  
  // Lógica do Alarme movida para cá
  const { initAudio, startRinging, stopRinging } = useAlarm();
  const listenerInitialized = useRef(false);
  const initialLoadDone = useRef(false);
  const silentAudioRef = useRef<HTMLAudioElement | null>(null);
  
  const app = getFirebaseApp();

  // EFEITO DE AUTENTICAÇÃO CENTRALIZADO
  useEffect(() => {
    if (!app) {
        setUser(null);
        return;
    }
    const auth = getAuth(app);
    
    setPersistence(auth, browserLocalPersistence)
      .then(() => {
        const unsubscribe = onAuthStateChanged(auth, (user) => {
          if (user) {
             const isUserAdmin = ADMIN_USER_UIDS.includes(user.uid);
             if (isUserAdmin) {
                setUser(user);
             } else {
                toast({
                    title: "Acesso Negado",
                    description: "Você não tem permissão para acessar a área de administração.",
                    variant: "destructive",
                });
                logout(); // Usa a função de logout do store para limpar o estado
             }
          } else {
            setUser(null);
            router.replace('/login');
          }
        });
        return unsubscribe;
      })
      .catch((error) => {
        console.error("Erro ao definir persistência:", error);
        setUser(null);
      });
  }, [app, setUser, router, toast, logout]);
  

  // Efeito para configurar o listener de novos pedidos
  useEffect(() => {
    const isUserAdmin = user && ADMIN_USER_UIDS.includes(user.uid);
    if (!isUserAdmin || listenerInitialized.current || !app) {
        return;
    }

    const db = getFirestore(app);
    const ordersQuery = query(collection(db, "orders"));

    const unsubscribe = onSnapshot(ordersQuery, (snapshot) => {
        if (!initialLoadDone.current) {
            initialLoadDone.current = true;
            return;
        }

        snapshot.docChanges().forEach((change) => {
            const orderData = change.doc.data();
            if (change.type === "added" && orderData.status === "pending") {
                startRinging();
            }
        });
    }, (error) => {
        console.error("[ERRO DE LISTENER]:", error);
        toast({
            title: "Erro de Conexão",
            description: "Não foi possível monitorar novos pedidos.",
            variant: "destructive",
        });
    });
    
    listenerInitialized.current = true;

    return () => {
        unsubscribe();
        stopRinging();
    };
  }, [user, app, startRinging, stopRinging, toast]);

    // Efeito para o "batimento cardíaco" silencioso
  useEffect(() => {
    const initAndPlaySilentAudio = () => {
      if (!silentAudioRef.current) {
        silentAudioRef.current = new Audio('/sounds/silent.mp3');
        silentAudioRef.current.loop = true;
      }
      
      const playPromise = silentAudioRef.current.play();
      if (playPromise !== undefined) {
        playPromise.catch(error => {
          console.log("Interação do usuário necessária para áudio de fundo.");
        });
      }
    };
    
    // Toca o som a cada 30 segundos
    const interval = setInterval(() => {
      if (silentAudioRef.current && silentAudioRef.current.paused) {
        silentAudioRef.current.play().catch(e => {});
      }
    }, 30000);

    // Inicializa na primeira interação do usuário
    window.addEventListener('click', initAndPlaySilentAudio, { once: true });
    window.addEventListener('touchstart', initAndPlaySilentAudio, { once: true });

    return () => {
      clearInterval(interval);
      if (silentAudioRef.current) {
        silentAudioRef.current.pause();
      }
      window.removeEventListener('click', initAndPlaySilentAudio);
      window.removeEventListener('touchstart', initAndPlaySilentAudio);
    };
  }, []);

  const handleUserGesture = useCallback(() => {
    initAudio();
  }, [initAudio]);
  
  if (isAuthLoading || !user) {
    return (
      <div className="flex items-center justify-center min-h-screen">
        <Loader2 className="h-8 w-8 animate-spin" />
        <span className="ml-2">Verificando permissões...</span>
      </div>
    );
  }

  // O clique para inicializar o áudio está no container principal
  return (
    <div className="flex min-h-screen" onClick={handleUserGesture}>
        <AdminSidebar />
        <AdminContent>
            {children}
        </AdminContent>
    </div>
  );
}


// O export default envolve tudo com o Provider
export default function AdminLayout({ children }: { children: React.ReactNode }) {
  return (
    <AlarmProvider>
      <AdminLayoutController>
        {children}
      </AdminLayoutController>
    </AlarmProvider>
  );
}
