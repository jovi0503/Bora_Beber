
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer pessoa leia imagens de produtos.
    match /products/{allPaths=**} {
      allow read;
      // Permite a escrita (criação, atualização, exclusão) de imagens
      // apenas se o usuário estiver autenticado.
      allow write: if request.auth != null;
    }

    // Você pode adicionar outras regras para outros diretórios aqui, se necessário.
    // Ex: match /user-profiles/{userId}/{allPaths=**} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }
  }
}
